<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.sharingpresetmusik.controller.RegisterController"
      stylesheets="@css/style.css"
      styleClass="login-root"
      alignment="CENTER"
      spacing="0"
      prefWidth="400" prefHeight="580">

    <VBox alignment="CENTER_LEFT"
          spacing="20"
          styleClass="login-card"
          maxWidth="340" minWidth="300">

        <padding><Insets top="44" right="40" bottom="44" left="40"/></padding>

        <!-- Logo -->
        <Label text="PresetMusik" styleClass="login-logo"/>

        <!-- Subtitle -->
        <Label text="Buat akun baru" styleClass="login-subtitle"/>

        <!-- Spacer -->
        <Region prefHeight="4"/>

        <!-- Username -->
        <VBox spacing="6">
            <Label text="USERNAME" styleClass="field-label"/>
            <TextField fx:id="usernameField"
                       promptText="Masukkan username..."
                       styleClass="login-input"/>
        </VBox>

        <!-- Email -->
        <VBox spacing="6">
            <Label text="EMAIL" styleClass="field-label"/>
            <TextField fx:id="emailField"
                       promptText="nama@email.com"
                       styleClass="login-input"/>
        </VBox>

        <!-- Password -->
        <VBox spacing="6">
            <Label text="PASSWORD" styleClass="field-label"/>
            <PasswordField fx:id="passwordField"
                           promptText="Minimal 6 karakter..."
                           styleClass="login-input"/>
        </VBox>

        <!-- Error -->
        <Label fx:id="errorLabel"
               text=""
               styleClass="error-label"
               wrapText="true"
               minHeight="0"/>

        <!-- Submit -->
        <Button text="DAFTAR"
                onAction="#handleRegister"
                styleClass="btn-primary"
                maxWidth="Infinity"
                prefHeight="40"/>

        <!-- Login link -->
        <HBox alignment="CENTER" spacing="6">
            <Label text="Sudah punya akun?" styleClass="login-hint"/>
            <Label text="Masuk"
                   styleClass="login-link"
                   onMouseClicked="#handleGoLogin"/>
        </HBox>

    </VBox>

</VBox>
