<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.presetmusik.PresetController"
            prefWidth="800" prefHeight="500"
            styleClass="root">

    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="20" styleClass="top-bar">
                <Label text="LOGO" styleClass="logo"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>

            <HBox alignment="CENTER" spacing="10" styleClass="search-container">
                <TextField fx:id="searchField" promptText="Search Bar" styleClass="search-field"/>
                <Button text="🔍" styleClass="search-btn"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="20" styleClass="center-container">

            <HBox spacing="10" alignment="CENTER_LEFT" styleClass="breadcrumb">
                <Label text="Jenis preset" styleClass="breadcrumb-active"/>
                <Label text=">" styleClass="breadcrumb-sep"/>
                <Label text="Genre" styleClass="breadcrumb-inactive"/>
                <Label text=">" styleClass="breadcrumb-sep"/>
                <Label text="Tipe Suara" styleClass="breadcrumb-inactive"/>
            </HBox>

            <!-- Profile Card -->
            <VBox styleClass="profile-card" spacing="15">
                <HBox spacing="20" alignment="CENTER_LEFT">
                    <StackPane styleClass="avatar">
                        <Label text="👤" style="-fx-font-size: 40px;"/>
                    </StackPane>

                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Synyster Gates Preset" styleClass="profile-name"/>
                        <Label text="Moses" styleClass="profile-role"/>
                        <Label text="⭐ 4.9 · 1,999 downloads" styleClass="profile-stats"/>
                    </VBox>
                </HBox>

                <Separator styleClass="separator"/>

                <!-- Tombol Download Preset & Demo Preset -->
                <HBox spacing="10" alignment="CENTER">
                    <Button text="Download Preset" styleClass="btn-preset" fx:id="downloadPresetBtn" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button text="Demo Preset" styleClass="btn-preset-secondary" fx:id="demoPresetBtn" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                </HBox>

                <!-- Volume Control -->
                <HBox spacing="10" alignment="CENTER">
                    <Label text="🔊" style="-fx-font-size: 12px;"/>
                    <Slider fx:id="volumeSlider" min="0" max="1" value="0.8" blockIncrement="0.05" HBox.hgrow="ALWAYS"/>
                    <Label fx:id="volumeLabel" text="80%" style="-fx-font-size: 10px; -fx-text-fill: #6b6762;"/>
                </HBox>

            </VBox>  <!-- Penutup profile-card -->

        </VBox>
    </center>

</BorderPane>