<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.sharingpresetmusik.controller.LoginController"
      stylesheets="@css/style.css"
      styleClass="login-root"
      alignment="CENTER"
      spacing="0"
      prefWidth="400" prefHeight="500">

    <VBox alignment="CENTER_LEFT"
          spacing="24"
          styleClass="login-card"
          maxWidth="340" minWidth="300">

        <padding><Insets top="44" right="40" bottom="44" left="40"/></padding>

        <!-- Logo -->
        <Label text="PresetMusik" styleClass="login-logo"/>

        <!-- Subtitle -->
        <Label text="Masuk ke akun kamu" styleClass="login-subtitle"/>

        <!-- Spacer kecil -->
        <Region prefHeight="4"/>

        <!-- Email field -->
        <VBox spacing="6">
            <Label text="EMAIL" styleClass="field-label"/>
            <TextField fx:id="usernameField"
                       promptText="nama@email.com"
                       styleClass="login-input"/>
        </VBox>

        <!-- Password field -->
        <VBox spacing="6">
            <Label text="PASSWORD" styleClass="field-label"/>
            <PasswordField fx:id="passwordField"
                           promptText="Masukkan password..."
                           styleClass="login-input"/>
        </VBox>

        <!-- Error -->
        <Label fx:id="errorLabel"
               text=""
               styleClass="error-label"
               wrapText="true"
               minHeight="0"/>

        <!-- Submit -->
        <Button text="MASUK"
                onAction="#handleLogin"
                styleClass="btn-primary"
                maxWidth="Infinity"
                prefHeight="40"/>

        <!-- Register link -->
        <HBox alignment="CENTER" spacing="6">
            <Label text="Belum punya akun?" styleClass="login-hint"/>
            <Label text="Daftar sekarang"
                   styleClass="login-link"
                   onMouseClicked="#handleGoRegister"/>
        </HBox>

    </VBox>

</VBox>
